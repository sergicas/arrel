# Supabase
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Stripe (client)
VITE_STRIPE_PUBLIC_KEY=pk_test_xxx

# Sentry (optional; Sentry is disabled if left blank)
VITE_SENTRY_DSN=

# Secret used by secureStorage to encrypt local data.
# Rotate to invalidate existing ciphertext. Do NOT reuse a real secret: the
# bundle ships to clients, so treat this as obfuscation, not true encryption.
VITE_SECRET_KEY=change-me

# Netlify functions (server-side only, do NOT prefix with VITE_)
SITE_URL=https://arrel.eu
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_ID=price_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated list of origins allowed to call the checkout function
ALLOWED_ORIGINS=https://arrel.eu,https://www.arrel.eu
